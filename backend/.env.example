# Copy to .env and fill in values.

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Strava env file written by strava-mcp setup_auth (already exists on this PC).
STRAVA_ENV_PATH=C:\Users\test\.strava-mcp.env

# Garmin tokens are auto-loaded from ~/.garminconnect/ — nothing to set.
